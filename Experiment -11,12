#calculate the square of any number
create or replace function sq1(n IN NUMBER) return varchar2
as
    c NUMBER;
BEGIN 
    c := n * n;
    RETURN ('square of ' || n || '= ' || c);
END;
/

or

create or replace function sq1(n IN NUMBER) return number
as
    c NUMBER;
BEGIN 
    c := n * n;
    RETURN c;
END;
/
#for output
select sq1(number) form dual;
