input m1 m2 m3 marks 
calculate total and percentage and check weather pass or fail using function and procedures dont use exceptions

CREATE OR REPLACE FUNCTION result_fn(m1 IN NUMBER, m2 IN NUMBER, m3 IN NUMBER)
RETURN VARCHAR2
AS
    total NUMBER;
    per NUMBER;
BEGIN
    total := m1 + m2 + m3;
    per := total / 3;

    IF per >= 40 THEN
        RETURN 'Total = ' || total || ', Percentage = ' || per || ', PASS';
    ELSE
        RETURN 'Total = ' || total || ', Percentage = ' || per || ', FAIL';
    END IF;
END;
/
#for output
SET SERVEROUTPUT ON;

BEGIN
    DBMS_OUTPUT.PUT_LINE(result_fn(50, 40, 30));
END;
/
