EXP 10
Exceptions
There are 2 types of exceptions
1)system defied 2)user defined
in system defined exceptions there is no_data found or max_rows found
in user defined exceptions out of range
system defined
create or replace procedure find_emp_id_1 (
    v_fname IN emp6.first_name%type,
    v_lname IN emp6.last_name%type
)
as
    v_emp_id emp6.emp_no%type;
begin
    select emp_no into v_emp_id
    from emp6
    where first_name = v_fname
    and last_name = v_lname;

    DBMS_OUTPUT.PUT_LINE('Employee Id is: ' || v_emp_id);

EXCEPTION
    when NO_DATA_FOUND then
        DBMS_OUTPUT.PUT_LINE('No employee found with given name.');
END;
/
#for output
begin
    find_emp_id('John', 'Smith');
    end;
    /
