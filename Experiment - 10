user defined exceptions
CREATE OR REPLACE PROCEDURE result_proc
AS
    v_m1 NUMBER;
    v_m2 NUMBER;
    v_m3 NUMBER;
    v_total NUMBER;
    v_perc NUMBER;
    v_result VARCHAR2(10);

    invalid_marks EXCEPTION;

BEGIN
    v_m1 := &m1;
    v_m2 := &m2;
    v_m3 := &m3;

    IF v_m1 < 0 OR v_m1 > 100 OR
       v_m2 < 0 OR v_m2 > 100 OR
       v_m3 < 0 OR v_m3 > 100 THEN
        RAISE invalid_marks;
    END IF;

    v_total := v_m1 + v_m2 + v_m3;
    v_perc := v_total / 3;

    IF v_perc >= 40 THEN
        v_result := 'PASS';
    ELSE
        v_result := 'FAIL';
    END IF;

    DBMS_OUTPUT.PUT_LINE('Total marks: ' || v_total);
    DBMS_OUTPUT.PUT_LINE('Percentage: ' || v_perc);
    DBMS_OUTPUT.PUT_LINE('Result: ' || v_result);

EXCEPTION
    WHEN invalid_marks THEN
        DBMS_OUTPUT.PUT_LINE('Enter valid marks (0-100)');
END;
/
#for output
SET SERVEROUTPUT ON;
EXEC result_proc;
