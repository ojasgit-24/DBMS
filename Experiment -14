4.design a trigger which will be fired when a new record is inserted or update for the following conditions:
a.salary should be more than 10000 for category 1.
b.salary should be more than 20000 for category 2.
c.salary should be more than 30000 for category 3.
create or replace trigger trg_salary
before insert or update on emp2
for  each row
begin
if :new.category=1 and :new.salary<=10000 then
RAISE_APPLICATION_ERROR(-20001,'Salary must be more than 10000 for category 1.');
elsif :new.category=2 and :new.salary<=20000 then
RAISE_APPLICATION_ERROR(-20002,'Salary must be more than 20000 for category 2.');
elsif :new.category=3 and :new.salary<=30000 then
RAISE_APPLICATION_ERROR(-20003,'Salary must be more than 30000 for category 3.');
end if;
end;
/
