1.create table emp2 with attributes empno as integer type, name as string and category as integer type
------------------------------------------------------------------------------------------------------------------
CREATE TABLE emp2 (
    empno INTEGER,
    name VARCHAR(50),
    category INTEGER
);
2.design trigger such that string values should be inserted or updated as uppercase only example string=upper(string)
create or replace trigger trg_uppercase
before update or insert on emp2
for each row 
begin
:NEW.name:=upper(:NEW.name);
end;
