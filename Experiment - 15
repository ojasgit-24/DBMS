using trigger
-------------------
create or replace trigger trg_max_min_salary1
before insert or update on emp2
COMPOUND TRIGGER
declare
vmax emp2.salary%TYPE;
vmin emp2.salary%TYPE;
v_upper emp2.salary%TYPE;
v_lower emp2.salary%TYPE;
BEFORE STATEMENT IS
begin
select max(salary), min(salary) into vmax, vmin from emp2;
v_upper := vmin * 10;
v_lower := vmax / 10;
END BEFORE STATEMENT;
BEFORE EACH ROW IS 
BEGIN
if :NEW.salary<v_lower or :NEW.salary>v_upper then
raise_application_error(-20001,'salary should be between ' || v_lower || ' and ' || v_upper);
end if;
END BEFORE EACH ROW;
end trg_max_min_salary1;
/
