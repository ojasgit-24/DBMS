update the maximum or minimum salary to be inserted(exp 14)
max salary = min x 10
min=max/10
consider the max salary is 35000 and min is 10000
max sal= 10000*10=1000000(upper limit)
min sal= 35000/10=3500(lower limit)
---------------------------------------------------------------------------------------------------
using procedures
---------------------
create or replace procedure max_min_salary
as
vmax emp2.salary%TYPE;
vmin emp2.salary%TYPE;
v_upper emp2.salary%TYPE;
v_lower emp2.salary%TYPE;
begin
select max(salary),min(salary)
into vmax, vmin
from emp2;
v_upper := vmin * 10;
v_lower := vmax / 10;
DBMS_OUTPUT.PUT_LINE('Maximum salary: ' || vmax);
DBMS_OUTPUT.PUT_LINE('Minimum salary: ' || vmin);
DBMS_OUTPUT.PUT_LINE('Upper limit (Min*10): ' || v_upper);
DBMS_OUTPUT.PUT_LINE('Lower limit (Max/10): ' || v_lower);
end;
/
output
begin
max_min_salary;
end;
/
