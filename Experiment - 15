create or replace trigger trg_day
before insert or update on emp2
begin
if to_char(sysdate,'day')='WEDNESDAY' then
RAISE_APPLICATION_ERROR(-20004,'no insertion or updation is allowed on Wednesday');
end if;
end;
/
