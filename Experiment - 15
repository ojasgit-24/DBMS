using variable
--------------------
CREATE OR REPLACE TRIGGER tr_day
BEFORE INSERT OR UPDATE ON emp2
FOR EACH ROW
DECLARE
    v_day VARCHAR2(10);
BEGIN
    v_day := TO_CHAR(SYSDATE, 'DY');
    IF v_day = 'WED' THEN
        RAISE_APPLICATION_ERROR(-20001, 'Insertion or updation is prohibited on ' || v_day);
    END IF;
END;
/
